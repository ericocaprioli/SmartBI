# Example environment variables for local development
# Copy this file to .env and fill the real values.

# OAuth portal used by the frontend login flow
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example
VITE_APP_ID=your-app-id

# Backend OAuth server URL used by the server SDK
OAUTH_SERVER_URL=https://your-oauth-server.example

# App-specific secrets
JWT_SECRET=replace-with-a-secret
DATABASE_URL=mysql://user:pass@localhost:3306/database

# Optional analytics vars
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
